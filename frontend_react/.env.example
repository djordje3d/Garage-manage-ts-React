# Recommended: Vite proxy (same origin, no CORS). vite.config.ts forwards /api -> http://localhost:4000
VITE_API_URL=/api

# Optional: same value as API_KEY in api/.env when the backend requires X-API-Key and you are not logged in.
# After login, the client sends JWT and omits this header.
VITE_API_KEY=postman-test-key

# Alternative: call API directly (ensure api/.env CORS_ORIGINS includes http://localhost:5173)
# VITE_API_URL=http://localhost:4000
