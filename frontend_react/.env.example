# Recommended: Vite proxy (same origin, no CORS). vite.config.ts forwards /api -> http://localhost:4000
VITE_API_URL=/api

# Optional: same value as API_KEY in api_nodejs/.env when the backend requires X-API-Key and you are not logged in.
# After login, the client sends JWT and omits this header.
VITE_API_KEY=postman-test-key

# Ticket images: static Vite server in APIPostgreSql/fileserver/storage (npm run dev → port 9009). No trailing slash.
VITE_FILESERVER_URL=http://localhost:9009

# Alternative: call API directly (ensure api_nodejs/.env CORS_ORIGINS includes http://localhost:5173)
# VITE_API_URL=http://localhost:4000
